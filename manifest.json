{
  "name": "Rural Health Tracker",
  "short_name": "HealthTrack",
  "description": "Offline-first clinical documentation and reporting system for ASHA and ANM workers.",
  "id": "com.healthtracker.rural.pwa",
  "start_url": "./index.html",
  "scope": "./",
  "lang": "en-IN",
  "dir": "ltr",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "minimal-ui", "standalone", "browser"],
  "background_color": "#0F172A",
  "theme_color": "#0F172A",
  "orientation": "portrait",
  "categories": ["medical", "government", "health", "productivity"],
  "iarc_rating_id": "e5-1234-5678",
  "prefer_related_applications": false,
  "related_applications": [],
  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },
  "file_handlers": [
    {
      "action": "./index.html#import",
      "accept": {
        "text/csv": [".csv"],
        "application/json": [".health"]
      },
      "icons": [
        { "src": "./icon.png", "sizes": "192x192", "type": "image/png" }
      ],
      "launch_type": "single-client"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+health",
      "url": "./index.html?query=%s"
    }
  ],
  "note_taking": {
    "new_note_url": "./index.html#new-note"
  },
  "share_target": {
    "action": "./index.html#share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "share_title",
      "text": "share_text",
      "url": "share_url",
      "files": [
        {
          "name": "media",
          "accept": ["image/*", "application/pdf"]
        }
      ]
    }
  },
  "shortcuts": [
    {
      "name": "Monthly Goshwara",
      "short_name": "Goshwara",
      "description": "View and finalize the monthly sub-centre report",
      "url": "./index.html#goshwara",
      "icons": [{ "src": "./icon.png", "sizes": "192x192" }]
    },
    {
      "name": "New Registration",
      "short_name": "Register",
      "description": "Register a new family or member",
      "url": "./index.html#register",
      "icons": [{ "src": "./icon.png", "sizes": "192x192" }]
    }
  ],
  "widgets": [
    {
      "name": "Daily Due List",
      "description": "Shows the count of health tasks due today",
      "tag": "due-list",
      "template": "due-list-template",
      "ms_ac_template": "due-list.json",
      "data": "due-list-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "./screenshot1.png",
          "sizes": "1080x1920",
          "type": "image/png"
        }
      ]
    }
  ],
  "icons": [
    {
      "src": "./icon.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "./icon.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    }
  ],
  "screenshots": [
    {
      "src": "./screenshot1.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Clinical Dashboard"
    },
    {
      "src": "./screenshot2.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Goshwara Report"
    }
  ]
}
